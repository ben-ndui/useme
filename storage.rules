rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Releases: upload réservé aux utilisateurs authentifiés, lecture publique pour le download
    match /releases/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }

    // Tout le reste: refusé par défaut
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
