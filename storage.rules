rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Releases: public read, authenticated write
    match /releases/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }

    // Profile photos: anyone can read, only owner can write
    match /profile_photos/{userId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Messaging attachments: authenticated users can read/write
    match /messaging/{conversationId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Studio room images
    match /studio_rooms/{studioId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Card background images: public read, only owner can write
    match /card_backgrounds/{userId}/{file} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
